{
  "name": "quickticket2queue",
  "productName": "Quick Ticket to Queue",
  "version": "0.0.5",
  "packageManager": "pnpm@10.32.1",
  "description": "Desktop app for quickly submitting ServiceNow tickets to common queues",
  "author": "cnjimbo",
  "main": "dist/main/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "ensure:install": "pnpm i",
    "gen:ipc": "tsx scripts/generate-ipc-methods.ts",
    "gen:favicon": "tsx scripts/generate-favicon.ts",
    "predev": "pnpm run ensure:install",
    "dev": "vite",
    "predebug": "pnpm run ensure:install",
    "debug": "vite -- --dsb-debug",
    "prebuild": "pnpm run gen:ipc",
    "build": "pnpm run clean && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "check": "pnpm run lint && pnpm run typecheck",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@doubleshot/nest-electron": "^0.2.11",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/microservices": "^11.1.16",
    "ajv": "^8.18.0",
    "axios": "^1.13.6",
    "builder-util-runtime": "^9.5.1",
    "call-bind-apply-helpers": "^1.0.2",
    "debug": "^4.4.3",
    "electron-store": "^11.0.2",
    "electron-unhandled": "^5.0.0",
    "electron-updater": "^6.6.2",
    "element-plus": "^2.13.5",
    "es-define-property": "^1.0.1",
    "es-object-atoms": "^1.1.1",
    "function-bind": "^1.1.2",
    "get-proto": "^1.0.1",
    "gopd": "^1.2.0",
    "math-intrinsics": "^1.1.0",
    "ms": "^2.1.3",
    "pinia": "^3.0.4",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@iconify-json/mdi": "^1.2.3",
    "@vitejs/plugin-vue": "6.0.4",
    "@vue/compiler-sfc": "3.5.30",
    "electron": "40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "rimraf": "6.1.3",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "7.3.1",
    "vite-plugin-doubleshot": "0.0.20",
    "vue-eslint-parser": "^10.4.0",
    "vue-router": "^5.0.3",
    "vue-tsc": "3.2.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,vue}": "eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@go-task/cli",
      "@nestjs/core",
      "electron",
      "esbuild",
      "sharp",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  },
  "volta": {
    "node": "24.14.0"
  }
}