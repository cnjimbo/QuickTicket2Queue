{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "ticket-options.schema.json",
    "title": "Ticket Queue Options",
    "description": "QuickTicket2Queue 默认队列配置文件。",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "items"
    ],
    "properties": {
        "$schema": {
            "type": "string",
            "title": "Schema 路径",
            "description": "JSON Schema 文件路径，建议固定为 ./ticket-options.schema.json",
            "examples": [
                "./ticket-options.schema.json"
            ]
        },
        "items": {
            "type": "array",
            "title": "默认队列列表",
            "description": "用于下拉选择和初始化的默认队列配置。",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "title": "队列配置项",
                "description": "每一项表示一个可选队列，包含显示描述与队列编码。",
                "required": [
                    "des",
                    "queue"
                ],
                "properties": {
                    "des": {
                        "type": "string",
                        "minLength": 1,
                        "title": "描述",
                        "description": "用户可读的队列说明，用于界面展示。",
                        "examples": [
                            "域名申请、解析"
                        ]
                    },
                    "queue": {
                        "type": "string",
                        "minLength": 1,
                        "title": "队列标识",
                        "description": "ServiceNow 队列名称/编码，提交工单时实际使用该值。",
                        "examples": [
                            "GBL-NETWORK DDI"
                        ]
                    }
                }
            }
        }
    }
}