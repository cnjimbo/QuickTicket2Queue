{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "./**/*.d.ts",
    "./src/render/**/*",
    "./src/preload/electron.ts",
    "./src/preload/auto-gen/**/*",
    "./src/render/utils/draft-leave-confirm.ts",
    "./scripts/app-version.ts",
    "vite.config.mts",
  ],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "rootDir": ".",
    "types": [
      "vite/client",
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router",
    ],
    "composite": true,
    "baseUrl": "./",
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "./dist/",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@render/*": [
        "src/render/*"
      ],
      "@main/*": [
        "src/main/*"
      ]
    },
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-typed-router",
      "vue-router/volar/sfc-route-blocks",
    ],
  },
  "exclude": [
    "./src/main/",
    "**/dist",
    "**/build",
    ".vscode",
    "**/.git",
    "**/build",
    "cache",
    "**/.vite/",
    "**/node_modules"
  ],
}